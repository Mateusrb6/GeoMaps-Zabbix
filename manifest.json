{
	"manifest_version": 2.0,
	"id": "geomap",
	"type": "widget",
	"name": "Geomap",
	"namespace": "Geomap",
	"version": "1.0",
	"author": "Vinicius Sousa",
	"description": "Utilizado o geomaps do zabbix como base",
	"url": "web_interface/frontend_sections/dashboards/widgets/geomap",
	"widget": {
		"js_class": "CWidgetGeoMap",
        "in": {
			"hostids": {
				"type": "_hostids"
			},
			"groupids": {
				"type": "_hostgroupids"
			}
		},
		"out": [
            {
				"type": "_hostid"
			},
            {
				"type": "_hostids"
			}
        ]
	},
	"actions": {
		"widget.geomap.view": {
			"class": "WidgetView"
		}
	},
	"assets": {
		"js": ["class.widget.js"]
	}
}
